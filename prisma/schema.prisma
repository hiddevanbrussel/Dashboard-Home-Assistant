generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Connection {
  id             String   @id @default(cuid())
  baseUrl        String
  encryptedToken String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Dashboard {
  id               String   @id @default(cuid())
  name             String
  theme            String   @default("auto")
  background       String?
  backgroundLight  String?
  backgroundDark   String?
  layout           String?
  widgets          String?
  welcomeTitle     String?
  welcomeSubtitle  String?
  roomCardSize     String?  // "normal" | "large" – size of all room cards
  createdAt        DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Room {
  id         String   @id @default(cuid())
  name       String
  entityIds  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model RoomDashboard {
  id                  String   @id @default(cuid())
  areaId              String   @unique
  name                String?
  icon                String?
  iconBackgroundColor  String?
  floor               String?
  layout              String?
  widgets             String?
  background          String?
  welcomeTitle        String?
  welcomeSubtitle     String?
  temperatureEntityId String?  // Entity to show temp under room title (e.g. sensor.woonkamer_temperature)
  humidityEntityId    String?  // Entity to show humidity under room title (e.g. sensor.woonkamer_humidity)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model EnergyDashboard {
  id                      String   @id @default(cuid())
  layout                  String?
  widgets                 String?
  background              String?
  backgroundLight         String?
  backgroundDark          String?
  welcomeTitle            String?
  welcomeSubtitle         String?
  costPerKwh              Float?   // Energiecontract: kosten per kWh (€)
  networkFeesPerDay       Float?   // Netbeheerkosten per dag (€)
  fixedDeliveryCostMonth  Float?   // Vaste leveringskosten per maand (€)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model Child {
  id        String   @id @default(cuid())
  name      String
  emoji     String?
  color     String?   // hex, e.g. "#FF6B6B"
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Chore {
  id          String   @id @default(cuid())
  title       String
  points      Int      @default(1)
  frequency   String   // "daily" | "weekdays" | "weekly"
  icon        String?  // lucide icon name, e.g. "Backpack"
  order       Int      @default(0)
  childIds    String?  // JSON array of Child IDs; null = all children
  timesPerDay Int      @default(1) // 1 or 2 (e.g. morning + evening)
  shared      Boolean  @default(false) // true = first completer gets points, task disappears for others
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChoreCompletion {
  id          String   @id @default(cuid())
  choreId     String
  childId     String
  date        String   // "YYYY-MM-DD": today for daily, Monday of week for weekly
  completedAt DateTime @default(now())

  @@unique([choreId, childId, date])
}
