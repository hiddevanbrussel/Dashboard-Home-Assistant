DATABASE_URL="file:./prisma/dev.db"
APP_SECRET="your-32-byte-secret-for-encryption-change-in-production"
NEXT_PUBLIC_APP_NAME="Home Assistant Dashboard Builder"
# Default UI language: en (English) or nl (Dutch). Users can override in Settings.
NEXT_PUBLIC_DEFAULT_LANGUAGE="en"

# Pexels API key for screensaver photos (free at pexels.com/api)
PEXELS_API_KEY=""

# Optional: passcode to allow "Install update" from Settings > System. If set, users must enter this code to run git pull + build.
# UPDATE_PASSCODE=""
